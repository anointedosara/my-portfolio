# ----------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the values.
# ----------------------------------------------------------------------------

# MongoDB connection string (MongoDB Atlas or local).
# Atlas example: mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/portfolio?retryWrites=true&w=majority
# Local example: mongodb://127.0.0.1:27017/portfolio
MONGODB_URI=

# Admin dashboard login (used at /admin/login)
ADMIN_EMAIL=anointedosara@gmail.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret used to sign the admin session cookie (any long random string).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-secret-string

# Public site URL (used for SEO metadata / sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
